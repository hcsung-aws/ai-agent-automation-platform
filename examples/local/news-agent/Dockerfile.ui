# Chainlit UI 컨테이너 (Fargate 배포용)
FROM python:3.11-slim

WORKDIR /app

COPY agents/requirements.txt requirements-agents.txt
COPY requirements-ui.txt .
RUN pip install --no-cache-dir -r requirements-agents.txt -r requirements-ui.txt

COPY agents/ agents/
COPY app.py config.py feedback_store.py ./

EXPOSE 8000
CMD ["chainlit", "run", "app.py", "--host", "0.0.0.0", "--port", "8000"]
