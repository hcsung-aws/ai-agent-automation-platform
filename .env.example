# 환경 변수 설정 예시
# 이 파일을 .env로 복사하고 값을 설정하세요

# AWS 리전
AWS_REGION=us-east-1

# Bedrock Knowledge Base (선택 - 시맨틱 검색 필요 시)
KNOWLEDGE_BASE_ID=
KB_DATA_SOURCE_ID=

# S3 Knowledge Base (Bedrock KB 없이 S3 직접 검색)
# CDK 배포 후 출력되는 버킷명 입력
KB_S3_BUCKET=
KB_S3_PREFIX=knowledge-base

# 로컬 Knowledge Base 경로 (기본값: ./knowledge-base)
LOCAL_KB_PATH=./knowledge-base
